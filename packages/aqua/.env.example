# -----------------------------------------------------------------------
# aqua — environment variables
#
# Copy this file to `.env` in this same directory (packages/aqua/.env)
# and fill in real values. `.env` is loaded automatically on startup by
# src/load-env.ts — nothing else to configure.
#
# See src/env.config.ts for how each variable is parsed/typed and where
# it's used.
# -----------------------------------------------------------------------

# --- Core server ---------------------------------------------------------

# Runtime mode. "development" | "production" | "test". Defaults to "development".
NODE_ENV=development

# Port the Express server listens on. Defaults to 3000.
PORT=3000

# --- Auth ------------------------------------------------------------------

# Shared secret required in the `Authorization` header for
# POST /api/notification. Falls back to config.json's "key" field if unset.
API_KEY=

# --- Endpoint-specific API keys ---------------------------------------------

# Bearer token for the Lumenfall image-generation API.
# Used by: GET/POST /ai/lumenfall
LUMENFALL_API=

# API key for the `shoti` client. Falls back to config.json's "shotikey"
# field if unset.
# Used by: GET/POST /random/shoti
SHOTI_APIKEY=

# --- Advanced (rarely needed) -----------------------------------------------

# Override which .env file load-env.ts reads. Leave unset to use the
# default lookup (packages/aqua/.env, then the monorepo root .env).
# DOTENV_CONFIG_PATH=
