entrypoint = "packages/aqua/src/app.ts"
modules = ["web", "nodejs-24"]
hidden = [".config", "package-lock.json"]

[gitHubImport]
requiredFiles = [".replit", "replit.nix", "package.json", "package-lock.json"]

[nix]
channel = "stable-25_05"
packages = ["unzip"]

[deployment]
build = ["npm", "run", "build"]
run = ["node", "packages/aqua/dist/app.js"]
deploymentTarget = "autoscale"
ignorePorts = false

[agent]
expertMode = true

[[ports]]
localPort = 5000
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install && npm run build && PORT=5000 node packages/aqua/dist/app.js"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
