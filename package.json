{
  "name": "aqua-monorepo",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20",
    "npm": "10.8.2"
  },
  "scripts": {
    "dev": "npm run dev -w aqua",
    "dev:web": "npm run dev -w web",
    "build": "npm run build -w web && npm run build -w aqua",
    "start": "npm run start -w aqua",
    "aqua": "npm run dev -w aqua",
    "web": "npm run dev -w web"
  }
}